# Ignore everything by default
*

# Allow critical project configuration and documentation
!.gitignore
!README.md
!LICENSE*
!CMakeLists.txt

# Allow source and include directories
!include/
!include/**
!src/
!src/**
!cli/
!cli/**
!python/
!python/**
!examples/
!examples/**

# Exclude specific garbage/build artifacts EVEN within allowed directories
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/*.o
**/*.obj
**/*.exe
**/*.dll
**/*.so
**/*.dylib
**/*.a
**/*.lib
**/*.pdb
**/*.ilk
**/*.exp
**/.DS_Store
**/Thumbs.db
**/*.tmp
**/*.temp
**/*.log
